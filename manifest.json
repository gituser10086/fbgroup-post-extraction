{
  "manifest_version": 3,
  "name": "FB Group 帖子采集器",
  "version": "2.0.0",
  "description": "在 Facebook Group 页面一键采集帖子，自动存本地，支持导出 JSON/CSV/TXT",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://www.facebook.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "FB Group 帖子采集器"
  },
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/groups/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
